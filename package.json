{
  "name": "@vaultbase/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for Vaultbase — typed REST + WS/SSE client",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./realtime": {
      "types": "./dist/realtime/index.d.ts",
      "import": "./dist/realtime/index.js",
      "require": "./dist/realtime/index.cjs"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "require": "./dist/codegen/index.cjs"
    },
    "./migrate": {
      "types": "./dist/migrate/index.d.ts",
      "import": "./dist/migrate/index.js",
      "require": "./dist/migrate/index.cjs"
    },
    "./flags": {
      "types": "./dist/flags/index.d.ts",
      "import": "./dist/flags/index.js",
      "require": "./dist/flags/index.cjs"
    },
    "./flags/react": {
      "types": "./dist/flags/react.d.ts",
      "import": "./dist/flags/react.js",
      "require": "./dist/flags/react.cjs"
    },
    "./openfeature": {
      "types": "./dist/flags/openfeature.d.ts",
      "import": "./dist/flags/openfeature.js",
      "require": "./dist/flags/openfeature.cjs"
    }
  },
  "bin": {
    "vb-types": "./dist/codegen/bin.js",
    "vb-migrate": "./dist/migrate/bin.js",
    "vb-flags": "./dist/codegen/flags-bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "vaultbaseServerCompat": ">=0.1 <2.0",
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "vaultbase",
    "baas",
    "sdk",
    "typescript",
    "realtime"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "sideEffects": false
}
